	)
	(text "\"standard\"\n1 - mic+\n2 - left spkr-\n3 - right spkr+\n4 - GND\nNokia 3210\n1 - mic-\n2 - spkr+\n3 - mic+\n4 - spkr-\nNokia 8210 (on EV board mono headset)\n1 - gnd\n2 - spkr+\n3 - mic+\nseparated direct telephone headset PTT\n1 - spk-\n2 - mic+\n3 - mic-\n4 - spk+"
